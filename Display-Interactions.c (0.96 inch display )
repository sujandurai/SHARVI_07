// ================= QUIZ =================
int quizState = 0;       // 0 = new question, 1 = wait answer, 2 = result delay
int quizIndex = 0;
bool quizCorrectYes = false;

// 0 = number, 1 = letter, 2 = shape
const uint8_t QUIZ_TYPES[10]       = {0,1,2,0,1,2,0,1,2,0};
const int QUIZ_DISPLAY_ITEMS[10]   = {5,0,3,9,1,0,7,12,2,8};
const int QUIZ_ASK_ITEMS[10]       = {5,0,3,9,25,0,2,12,2,0};

void showQuizItem(int type, int item)
{
  if (type == 0) displayPattern(NUMBERS[item]);
  else if (type == 1) displayPattern(LETTERS[item]);
  else displayPattern(SHAPES[item]);
}

void startQuizQuestion()
{
  if (quizIndex >= 10) quizIndex = 0;

  int type = QUIZ_TYPES[quizIndex];
  int displayItem = QUIZ_DISPLAY_ITEMS[quizIndex];
  int askItem = QUIZ_ASK_ITEMS[quizIndex];

  quizCorrectYes = (displayItem == askItem);

  showQuizItem(type, displayItem);

  Serial.println("----- QUIZ QUESTION -----");

  if(type == 0)
  {
    Serial.print("Is this number ");
    Serial.print(askItem);
    Serial.println(" ?");
  }
  else if(type == 1)
  {
    Serial.print("Is this letter ");
    Serial.print((char)('A' + askItem));
    Serial.println(" ?");
  }
  else if(type == 2)
  {
    Serial.print("Is this shape number ");
    Serial.print(askItem + 1);
    Serial.println(" ?");
  }

  Serial.println("Press YES or NO Touch");
  Serial.println("-----------------------");

  quizState = 1;
}
// ================= RESET HELPERS =================
void resetMazePlayer()
{
  px = 0;
  py = 7;
}

void resetModeState()
{
  indexItem = 0;
  introPlayed = false;
  lastDisplayTime = 0;

  if (mode == MODE_MAZE)
  {
    resetMazePlayer();
    lastBlinkTime = 0;
    blinkState = true;
  }

  if (mode == MODE_QUIZ)
  {
    quizState = 0;
  }
}

// ================= MODE INTRO =================
void playModeIntro()
{
  if (introPlayed) return;

  if (mode == MODE_LETTERS) playTrack(6);
  else if (mode == MODE_NUMBERS) playTrack(33);
  else if (mode == MODE_SHAPES) playTrack(44);
  else if (mode == MODE_MAZE) playTrack(57);
  else if (mode == MODE_QUIZ) playTrack(61);

  delay(1000);
  introPlayed = true;
}

// ================= MODE CHANGE =================
void handleModeTouch()
{
  if (risingTouch(TOUCH_MODE, MODE_DEBOUNCE))
  {
    mode++;
    if (mode > MODE_QUIZ) mode = MODE_LETTERS;
    resetModeState();
  }
}

// ================= MAZE DRAW =================
void drawMaze()
{
  mx.clear();

  for (int y = 0; y < 8; y++)
  {
    for (int x = 0; x < 8; x++)
    {
      if (mazes[mazeLevel][y][x] == 1)
      {
        mx.setPoint(y, x, true);
      }
    }
  }

  if (blinkState)
  {
    mx.setPoint(goalY, goalX, true);
  }

  mx.setPoint(py, px, true);
  mx.update();
}

// ================= SETUP =================
void setup()
{
  pinMode(TOUCH_MODE, INPUT);
  pinMode(TOUCH_YES, INPUT);
  pinMode(TOUCH_NO, INPUT);

  Serial.begin(9600);
  BT.begin(9600);
  DF.begin(9600);

  mx.begin();
  mx.control(MD_MAX72XX::INTENSITY, 5);
  clearDisplay();
//===================================================
//display servo intialize...
  display.begin();

  horizontalServo.attach(9);
  verticalServo.attach(10);

  centerPosition();
  delay(500);
  //======================================
  delay(1500);
  setVolume(30);

  startupAnimation();
 
  resetModeState();
}

// ================= LOOP =================
void loop()
{
  handleModeTouch();
  playModeIntro();

  // ================= LETTERS =================
  if (mode == MODE_LETTERS)
  {
    if (millis() - lastDisplayTime >= LETTER_INTERVAL)
    {
      displayPattern(LETTERS[indexItem]);
      delay(1000);
      playTrack(7 + indexItem);   // 7..32

      indexItem++;
      if (indexItem >= 26) indexItem = 0;

      lastDisplayTime = millis();
    }
  }

  // ================= NUMBERS =================
  else if (mode == MODE_NUMBERS)
  {
    if (millis() - lastDisplayTime >= NUMBER_INTERVAL)
    {
      displayPattern(NUMBERS[indexItem]);
      delay(100);
      playTrack(34 + indexItem);  // 34..43

      indexItem++;
      if (indexItem >= 10) indexItem = 0;

      lastDisplayTime = millis();
    }
  }

  // ================= SHAPES =================
  else if (mode == MODE_SHAPES)
  {
    if (millis() - lastDisplayTime >= SHAPE_INTERVAL)
    {
      displayPattern(SHAPES[indexItem]);
      delay(3000);
      playTrack(45 + indexItem);  // 45..56

      indexItem++;
      if (indexItem >= 12) indexItem = 0;

      lastDisplayTime = millis();
    }
  }

  // ================= MAZE =================
  else if (mode == MODE_MAZE)
  {
    if (millis() - lastBlinkTime >= BLINK_INTERVAL)
    {
      blinkState = !blinkState;
      lastBlinkTime = millis();
    }

    if (BT.available())
    {
      char c = toupper(BT.read());

      if (c == 'F' && py > 0 && mazes[mazeLevel][py - 1][px] == 0) py--;
      if (c == 'B' && py < 7 && mazes[mazeLevel][py + 1][px] == 0) py++;
      if (c == 'L' && px > 0 && mazes[mazeLevel][py][px - 1] == 0) px--;
      if (c == 'R' && px < 7 && mazes[mazeLevel][py][px + 1] == 0) px++;
    }

    drawMaze();

    if (px == goalX && py == goalY)
    {
      playTrack(58);   // maze solved
      delay(600);

      mazeLevel++;
      if (mazeLevel >= 7) mazeLevel = 0;

      resetMazePlayer();
      drawMaze();
    }
  }

  // ================= QUIZ =================
  else if (mode == MODE_QUIZ)
  {
    if (quizState == 0)
    {
      startQuizQuestion();
    }
    else if (quizState == 1)
    {
      if (risingTouch(TOUCH_YES, MODE_DEBOUNCE))
      {
        if (quizCorrectYes)
        {
          displayPattern(SMILE);
          playTrack(59);   // correct
        }
        else
        {
          displayPattern(SAD);
          playTrack(60);   // wrong
        }

        quizResultTime = millis();
        quizState = 2;
      }

      if (risingTouch(TOUCH_NO, MODE_DEBOUNCE))
      {
        if (!quizCorrectYes)
        {
          displayPattern(SMILE);
          playTrack(59);   // correct
        }
        else
        {
          displayPattern(SAD);
          playTrack(60);   // wrong
        }

        quizResultTime = millis();
        quizState = 2;
      }
    }
    else if (quizState == 2)
    {
      if (millis() - quizResultTime >= QUIZ_DELAY)
      {
        quizIndex++;
        if (quizIndex >= 10) quizIndex = 0;
        quizState = 0;
      }
    }
  }
}
