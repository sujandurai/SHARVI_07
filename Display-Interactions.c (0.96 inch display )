void drawEyesOffset(int offsetY) {
  display.drawRBox(20, offsetY, 35, 25, 6); // Left eye
  display.drawRBox(73, offsetY, 35, 25, 6); // Right eye
}

// =======================
// 👁 BLINK FUNCTION
// =======================
void blinkEyes() {
  display.clearBuffer();
  drawEyesOffset(20); // Open
  display.sendBuffer();
  delay(800);

  display.clearBuffer(); // Closed
  display.drawBox(20, 32, 35, 4);
  display.drawBox(73, 32, 35, 4);
  display.sendBuffer();
  delay(200);
}

// =======================
// 👀 DRAW EYES ANY POSITION
// =======================
void drawEyes(int lX, int rX, int lW, int lH, int rW, int rH, int offsetY) {
  display.clearBuffer();
  display.drawRBox(lX, eyeY + offsetY, lW, lH, 6); // Left
  display.drawRBox(rX, eyeY + offsetY, rW, rH, 6); // Right
  display.sendBuffer();
}

// =======================
// 👁 BLINK AT CURRENT
// =======================
void blinkEyesAtCurrent(int lX, int rX, int offsetY) {
  // Close
  display.clearBuffer();
  display.drawBox(lX, eyeY + 7 + offsetY, leftEyeW, 4);
  display.drawBox(rX, eyeY + 7 + offsetY, rightEyeW, 4);
  display.sendBuffer();
  delay(200);

  // Open
  drawEyes(lX, rX, leftEyeW, leftEyeH, rightEyeW, rightEyeH, offsetY);
  delay(200);
}

// =======================
// 👀 MOVE RIGHT
// =======================
void moveRight() {
  int steps = 10;
  int targetLeftX = leftEyeX + 8;
  int targetRightX = rightEyeX + 18;
  int targetOffsetY = -15;

  int startLeftX = leftEyeX;
  int startRightX = rightEyeX;
  int startOffsetY = 0;

  for (int i = 0; i <= steps; i++) {
    int lX = startLeftX + (targetLeftX - startLeftX) * i / steps;
    int rX = startRightX + (targetRightX - startRightX) * i / steps;
    int offsetY = startOffsetY + (targetOffsetY - startOffsetY) * i / steps;
    drawEyes(lX, rX, leftEyeW, leftEyeH, rightEyeW, rightEyeH, offsetY);
    delay(50);
  }

  for (int i = 0; i < 2; i++)
    blinkEyesAtCurrent(targetLeftX, targetRightX, targetOffsetY);

  for (int i = 0; i <= steps; i++) {
    int lX = targetLeftX + (leftEyeX - targetLeftX) * i / steps;
    int rX = targetRightX + (rightEyeX - targetRightX) * i / steps;
    int offsetY = targetOffsetY + (0 - targetOffsetY) * i / steps;
    drawEyes(lX, rX, leftEyeW, leftEyeH, rightEyeW, rightEyeH, offsetY);
    delay(50);
  }

  blinkEyesAtCurrent(leftEyeX, rightEyeX, 0);
}

// =======================
// 👀 MOVE LEFT
// =======================
void moveLeft() {
  int steps = 10;
  int targetLeftX = leftEyeX - 18;
  int targetRightX = rightEyeX - 8;
  int targetLeftW = rightEyeW;
  int targetLeftH = rightEyeH;
  int targetRightW = leftEyeW;
  int targetRightH = leftEyeH;
  int targetOffsetY = -15;

  int startLeftX = leftEyeX;
  int startRightX = rightEyeX;
  int startOffsetY = 0;

  for (int i = 0; i <= steps; i++) {
    int lX = startLeftX + (targetLeftX - startLeftX) * i / steps;
    int rX = startRightX + (targetRightX - startRightX) * i / steps;
    int offsetY = startOffsetY + (targetOffsetY - startOffsetY) * i / steps;

    int lW = leftEyeW + (targetLeftW - leftEyeW) * i / steps;
    int lH = leftEyeH + (targetLeftH - leftEyeH) * i / steps;
    int rW = rightEyeW + (targetRightW - rightEyeW) * i / steps;
    int rH = rightEyeH + (targetRightH - rightEyeH) * i / steps;

    drawEyes(lX, rX, lW, lH, rW, rH, offsetY);
    delay(50);
  }

  for (int i = 0; i < 2; i++)
    blinkEyesAtCurrent(targetLeftX, targetRightX, targetOffsetY);

  for (int i = 0; i <= steps; i++) {
    int lX = targetLeftX + (leftEyeX - targetLeftX) * i / steps;
    int rX = targetRightX + (rightEyeX - targetRightX) * i / steps;
    int offsetY = targetOffsetY + (0 - targetOffsetY) * i / steps;
    drawEyes(lX, rX, leftEyeW, leftEyeH, rightEyeW, rightEyeH, offsetY);
    delay(50);
  }

  blinkEyesAtCurrent(leftEyeX, rightEyeX, 0);
}

// =======================
// 😡 RAGE EYES
// =======================
void rageEyes() {
  int steps = 5;
  int shrink = 5;

  int originalLeftW = leftEyeW;
  int originalLeftH = leftEyeH;
  int originalRightW = rightEyeW;
  int originalRightH = rightEyeH;

  for (int i = 0; i <= steps; i++) {
    int lW = originalLeftW - shrink * i / steps;
    int lH = originalLeftH - shrink * i / steps;
    int rW = originalRightW - shrink * i / steps;
    int rH = originalRightH - shrink * i / steps;
    drawEyes(leftEyeX, rightEyeX, lW, lH, rW, rH, 0);
    delay(50);
  }

  for (int i = 0; i < 12; i++) {
    int lX = random(5, 45);
    int rX = random(60, 120);
    int offsetY = random(-10, 10);
    drawEyes(lX, rX, originalLeftW - shrink, originalLeftH - shrink,
             originalRightW - shrink, originalRightH - shrink, offsetY);
    delay(100);
  }

  for (int i = 0; i < 6; i++) {
    int offsetY = (i % 2 == 0) ? -3 : 3;
    drawEyes(leftEyeX, rightEyeX, originalLeftW - shrink, originalLeftH - shrink,
             originalRightW - shrink, originalRightH - shrink, offsetY);
    delay(80);
  }

  for (int i = 0; i <= steps; i++) {
    int lW = (originalLeftW - shrink) + shrink * i / steps;
    int lH = (originalLeftH - shrink) + shrink * i / steps;
    int rW = (originalRightW - shrink) + shrink * i / steps;
    int rH = (originalRightH - shrink) + shrink * i / steps;
    int offsetY = (3 - 0) * (steps - i) / steps;
    drawEyes(leftEyeX, rightEyeX, lW, lH, rW, rH, offsetY);
    delay(50);
  }

  blinkEyesAtCurrent(leftEyeX, rightEyeX, 0);
}

// =======================
// 😎 UPGRADED DEFAULT EYES MODE
// =======================
void defaultEyes() {
  static unsigned long lastBlink = 0;  // track last blink time
  int steps = 20;
  int maxOffsetX = 5;   // horizontal scan
  int maxOffsetY = 2;   // vertical bounce
  int shineSize = 3;    // eye sparkle size
  unsigned long now = millis();

  for (int i = 0; i <= steps; i++) {
    int offsetX = maxOffsetX * sin(PI * i / steps);      // smooth left-right
    int offsetY = maxOffsetY * sin(2 * PI * i / steps);  // gentle up-down

    display.clearBuffer();

    // Draw left eye
    display.drawRBox(leftEyeX + offsetX, eyeY + offsetY, leftEyeW, leftEyeH, 6);
    display.drawCircle(leftEyeX + offsetX + leftEyeW - 6, eyeY + offsetY + 6, shineSize, U8G2_DRAW_ALL); // sparkle

    // Draw right eye
    display.drawRBox(rightEyeX + offsetX, eyeY + offsetY, rightEyeW, rightEyeH, 6);
    display.drawCircle(rightEyeX + offsetX + rightEyeW - 6, eyeY + offsetY + 6, shineSize, U8G2_DRAW_ALL); // sparkle

    display.sendBuffer();

    // Natural random blink every 2–5 seconds
    if (now - lastBlink > random(2000, 5000)) {
      blinkEyesAtCurrent(leftEyeX + offsetX, rightEyeX + offsetX, offsetY);
      lastBlink = now; // reset last blink time
    }

    delay(50); // adjust speed of scanning motion
  }
}
// =======================
// 🚀 FORWARD MODE EYES
// =======================
void forwardEyes() {

  int steps = 10;
  int scanAmount = 12;   // how far eyes scan left/right
  int shrink = 6;        // make eyes narrow

  // 1️⃣ Make eyes narrow (focused look)
  for (int i = 0; i <= steps; i++) {
    int lH = leftEyeH - shrink * i / steps;
    int rH = rightEyeH - shrink * i / steps;

    drawEyes(leftEyeX, rightEyeX, leftEyeW, lH, rightEyeW, rH, 0);
    delay(40);
  }

  // 2️⃣ Scan left
  for (int i = 0; i <= steps; i++) {
    int offsetX = -scanAmount * i / steps;

    drawEyes(leftEyeX + offsetX,
             rightEyeX + offsetX,
             leftEyeW,
             leftEyeH - shrink,
             rightEyeW,
             rightEyeH - shrink,
             0);
    delay(40);
  }

  // 3️⃣ Scan right
  for (int i = 0; i <= steps * 2; i++) {
    int offsetX = -scanAmount + (2 * scanAmount) * i / (steps * 2);

    drawEyes(leftEyeX + offsetX,
             rightEyeX + offsetX,
             leftEyeW,
             leftEyeH - shrink,
             rightEyeW,
             rightEyeH - shrink,
             0);
    delay(40);
  }

  // 4️⃣ Return to center
  for (int i = 0; i <= steps; i++) {
    int lH = (leftEyeH - shrink) + shrink * i / steps;
    int rH = (rightEyeH - shrink) + shrink * i / steps;

    drawEyes(leftEyeX, rightEyeX, leftEyeW, lH, rightEyeW, rH, 0);
    delay(40);
  }

  blinkEyesAtCurrent(leftEyeX, rightEyeX, 0);
}

// =======================
// 🔙 REVERSE SCAN MODE
// =======================
void reverseModeEyes() {

  int steps = 6;
  int expand = 3;       // how much eyes grow
  int bounceAmount = 4; // upward movement

  // 1️⃣ Slight enlarge (excited look)
  for (int i = 0; i <= steps; i++) {
    int lW = leftEyeW + expand * i / steps;
    int lH = leftEyeH + expand * i / steps;
    int rW = rightEyeW + expand * i / steps;
    int rH = rightEyeH + expand * i / steps;

    drawEyes(leftEyeX, rightEyeX, lW, lH, rW, rH, 0);
    delay(35);
  }

  // 2️⃣ Quick double blink (Vector style excitement)
  for (int i = 0; i < 2; i++) {
    blinkEyesAtCurrent(leftEyeX, rightEyeX, 0);
    delay(100);
  }

  // 3️⃣ Upward bounce (moving forward energy)
  for (int i = 0; i <= steps; i++) {
    int offsetY = -bounceAmount * i / steps;

    drawEyes(leftEyeX,
             rightEyeX,
             leftEyeW + expand,
             leftEyeH + expand,
             rightEyeW + expand,
             rightEyeH + expand,
             offsetY);
    delay(30);
  }

  // 4️⃣ Bounce back down
  for (int i = 0; i <= steps; i++) {
    int offsetY = -bounceAmount + bounceAmount * i / steps;

    drawEyes(leftEyeX,
             rightEyeX,
             leftEyeW + expand,
             leftEyeH + expand,
             rightEyeW + expand,
             rightEyeH + expand,
             offsetY);
    delay(30);
  }

  // 5️⃣ Smooth return to normal
  for (int i = 0; i <= steps; i++) {
    int lW = (leftEyeW + expand) - expand * i / steps;
    int lH = (leftEyeH + expand) - expand * i / steps;
    int rW = (rightEyeW + expand) - expand * i / steps;
    int rH = (rightEyeH + expand) - expand * i / steps;

    drawEyes(leftEyeX, rightEyeX, lW, lH, rW, rH, 0);
    delay(35);
  }

  blinkEyesAtCurrent(leftEyeX, rightEyeX, 0);
}


void speakMode() {

  unsigned long startTime = millis();
  unsigned long lastUpdate = 0;

  bool mouthOpen = false;
  int eyeOffset = 0;
  bool moveRight = true;

  while (millis() - startTime < 3500) {   // 3.5 seconds animation

    if (millis() - lastUpdate > 120) {
      lastUpdate = millis();

      display.clearBuffer();

      // =========================
      // Eye Movement
      // =========================
      if (moveRight) {
        eyeOffset += 2;
        if (eyeOffset >= 6) moveRight = false;
      } else {
        eyeOffset -= 2;
        if (eyeOffset <= -6) moveRight = true;
      }

      // Rounded Filled Eyes
      display.drawRBox(30 + eyeOffset, 18, 28, 28, 8);
      display.drawRBox(70 + eyeOffset, 18, 28, 28, 8);

      // =========================
      // Mouth Animation
      // =========================
      if (mouthOpen) {
        display.drawRBox(54, 50, 20, 12, 4);   // Big open
      } else {
        display.drawRBox(58, 52, 12, 6, 3);    // Small open
      }

      mouthOpen = !mouthOpen;

      display.sendBuffer();
    }
  }
}


