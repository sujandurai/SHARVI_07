Servo horizontalServo;
Servo verticalServo;

int horizontalCenter = 90;
int verticalCenter   = 90;

int moveAngle = 35;
int speedDelay = 8;

int currentH = 90;
int currentV = 90;

// =======================
//  SERVO SMOOTH MOVE
// =======================
void smoothMove(Servo &servo, int &currentPos, int targetPos) {

  if (currentPos < targetPos) {
    for (int pos = currentPos; pos <= targetPos; pos++) {
      servo.write(pos);
      delay(speedDelay);
    }
  } else {
    for (int pos = currentPos; pos >= targetPos; pos--) {
      servo.write(pos);
      delay(speedDelay);
    }
  }

  currentPos = targetPos;
}

void centerPosition() {
  smoothMove(horizontalServo, currentH, horizontalCenter);
  smoothMove(verticalServo, currentV, verticalCenter);
}

void servoLeft() {
  smoothMove(horizontalServo, currentH, horizontalCenter - moveAngle);
}

void servoRight() {
  smoothMove(horizontalServo, currentH, horizontalCenter + moveAngle);
}

void servoUp() {
  smoothMove(verticalServo, currentV, verticalCenter - moveAngle);
}

void servoDown() {
  smoothMove(verticalServo, currentV, verticalCenter + moveAngle);
}



// =======================
// 🚀 STARTUP ANIMATION
// =======================
void startupAnimation() {
   playTrack(1);
  typeWriterHello();
  delay(200);

   playTrack(2);
  // Eyes slide in from top
  for (int y = -30; y <= 20; y += 2) {
    display.clearBuffer();
    drawEyesOffset(y);
    display.sendBuffer();
    delay(20);
  }

  delay(300);

  // Small bounce
  for (int i = 0; i < 2; i++) {
    display.clearBuffer();
    drawEyesOffset(18);
    display.sendBuffer();
    delay(60);

    display.clearBuffer();
    drawEyesOffset(20);
    display.sendBuffer();
    delay(60);
  }

  delay(300);
  playTrack(3);
  // Blink once
  blinkEyes();
}

// =======================
// ✨ TYPEWRITER HELLO
// =======================
void typeWriterHello() {
  const char* text = "HELLO!";
  display.setFont(u8g2_font_ncenB14_tr);

  int16_t textWidth = display.getStrWidth(text);
  int x = (128 - textWidth) / 2;

  for (int i = 0; i <= 6; i++) {
    display.clearBuffer();
    display.drawStr(x, 30, String(text).substring(0, i).c_str());
    display.sendBuffer();
    delay(150);
  }
}

